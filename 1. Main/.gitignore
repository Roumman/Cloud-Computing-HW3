var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Игнорирование артефактов PyInstaller
*.manifest
*.spec

# Игнорирование логов установщика
pip-log.txt
pip-delete-this-directory.txt

# Игнорирование отчётов о покрытии кода и файлов юнит-тестов
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/

# Игнорирование файлов локализации
*.mo
*.pot

# Игнорирование специфичных для Django файлов
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal

# Игнорирование специфичных для Flask файлов
instance/
.webassets-cache

# Игнорирование артефактов Scrapy
.scrapy

# Игнорирование сгенерированных файлов Sphinx
docs/_build/

# Игнорирование выходных данных PyBuilder
target/

# Игнорирование чекпоинтов Jupyter Notebook
.ipynb_checkpoints

# Игнорирование настроек IPython
profile_default/
ipython_config.py

# Игнорирование файлов конфигурации pyenv
.python-version

# Игнорирование артефактов pipenv (кроме Pipfile.lock — по желанию)
#Pipfile.lock

# Игнорирование директорий PEP 582
__pypackages__/

